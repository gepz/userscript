{
  "name": "@userscript/flow-youtube-chat",
  "private": true,
  "version": "1.19.3",
  "description": "Userscript that flows YouTube live chat over the video, danmaku-style",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "lint": "eslint . --fix",
    "preinstall": "npx only-allow pnpm",
    "dev": "cross-env NODE_OPTIONS=\"--loader ts-node/esm\" TS_NODE_PROJECT=\"tsconfig.json\" webpack serve --config ./config/webpack.config.dev.ts",
    "build-webpack": "cross-env NODE_OPTIONS=\"--loader ts-node/esm\" TS_NODE_PROJECT=\"tsconfig.json\" webpack --config ./config/webpack.config.prod.ts",
    "build-prettify": "prettier --config ./config/prettier.config.js --write ./dist/main/index.user.js",
    "build": "run-s build-webpack build-prettify",
    "start": "pnpm dev"
  },
  "browserslist": [
    "> 0.15% and defaults"
  ],
  "dependencies": {
    "@effect/typeclass": "^0.40.0",
    "@fp-ts/optic": "^0.25.0",
    "@userscript/forward-to": "workspace:^1.0.4",
    "@userscript/tap-non-null": "workspace:^1.0.4",
    "@userscript/ui": "workspace:^1.1.3",
    "astring": "^1.9.0",
    "broadcast-channel": "^7.3.0",
    "deep-diff": "^1.0.2",
    "effect": "^3.21.4",
    "expression-eval": "^5.0.1",
    "fast-deep-equal": "^3.1.3",
    "hash-it": "^6.0.1",
    "hyperapp": "^2.0.22",
    "jsep": "^1.4.0",
    "lit-html": "^3.3.3",
    "lz-string": "^1.5.0",
    "micro-memoize": "^4.2.0",
    "rxjs": "^7.8.2",
    "sweetalert2": "^11.26.25",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^4.41.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/deep-diff": "^1.0.5",
    "@types/greasemonkey": "^4.0.7",
    "@types/node": "22.20.0",
    "@types/resize-observer-browser": "^0.1.11",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@userscript/cdn-from-dependency": "workspace:^1.0.4",
    "@userscript/eslint-config": "workspace:^1.0.4",
    "@userscript/webpack-config": "workspace:^1.0.5",
    "autoprefixer": "^10.5.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.4",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.6",
    "webpack-merge": "^6.0.1",
    "webpack-userscript": "^3.2.3"
  }
}
