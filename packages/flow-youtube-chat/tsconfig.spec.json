// Program for src including *.spec.ts files (tsconfig.build.json excludes
// them). Used by typed eslint on spec files, and referenced from
// tsconfig.json so editors assign spec files to this project (composite is
// what makes that reference lookup work; the implied .tsbuildinfo is
// gitignored). The excluded WIP directories mirror tsconfig.exclude.json;
// keep in sync.
{
  "extends": "../../tsconfig.bundle.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
  },
  "exclude": [
    "node_modules",
    "dist",
    "lib",
    "./src/filter/filterContextType",
    "./src/restrictedExpression",
    "./src/settingUI/EditableExpression",
    "./src/settingUI/filter",
    "./src/settingUI/filterPanel",
    "./src/type",
    "./src/typedExpression",
  ]
}
