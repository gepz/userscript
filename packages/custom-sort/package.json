{
  "name": "@userscript/custom-sort",
  "private": true,
  "version": "1.1.3",
  "description": "Userscript that sorts teaser listings on iwara.tv with a customizable sort function",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "lint": "eslint . --fix",
    "preinstall": "npx only-allow pnpm",
    "dev": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack serve --config ./config/webpack.config.dev.ts",
    "build-webpack": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack --config ./config/webpack.config.prod.ts",
    "build-prettify": "prettier --config ./config/prettier.config.js --write ./dist/main/index.user.js",
    "build": "run-s build-webpack build-prettify",
    "start": "pnpm dev"
  },
  "dependencies": {
    "@userscript/forward-to": "workspace:^1.0.4",
    "@userscript/tap-non-null": "workspace:^1.0.4",
    "broadcast-channel": "^7.3.0",
    "delay": "^7.0.0",
    "fp-ts": "^2.16.11",
    "loglevel": "^1.9.2",
    "mithril": "^2.3.8",
    "rxjs": "^7.8.2",
    "sweetalert2": "^11.26.25",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/greasemonkey": "^4.0.7",
    "@types/mithril": "^2.2.8",
    "@types/node": "26.1.0",
    "@userscript/cdn-from-dependency": "workspace:^1.0.4",
    "@userscript/eslint-config": "workspace:^1.0.4",
    "@userscript/webpack-config": "workspace:^1.0.5",
    "autoprefixer": "^10.5.2",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.4",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.6.1",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0",
    "webpack-merge": "^6.0.1",
    "webpack-userscript": "^3.2.3"
  }
}
