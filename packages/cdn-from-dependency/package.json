{
  "name": "@userscript/cdn-from-dependency",
  "version": "1.0.4",
  "description": "",
  "keywords": [],
  "license": "AGPL-3.0-or-later",
  "author": "",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "require": "./lib/index.js"
    }
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      ".": [
        "./lib/index.d.ts"
      ]
    }
  },
  "scripts": {
    "lint": "eslint . --fix",
    "preinstall": "npx only-allow pnpm",
    "dev": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack serve --config ./config/webpack.config.dev.ts",
    "build": "run-s build-lib build-umd",
    "build-lib": "tsc --project tsconfig.lib.json && tsc-alias -p tsconfig.lib.json",
    "build-umd": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack --config ./config/webpack.config.prod.ts",
    "start": "pnpm dev"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "22.20.0",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@userscript/eslint-config": "workspace:^1.0.4",
    "@userscript/webpack-config": "workspace:^1.0.5",
    "cross-env": "^7.0.3",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",
    "npm-run-all": "^4.1.5",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.6",
    "webpack-merge": "^6.0.1"
  }
}
