{
  "name": "@userscript/ui",
  "private": true,
  "version": "1.1.4",
  "description": "Shared hyperapp UI components and state helpers for userscript settings panels",
  "keywords": [],
  "license": "AGPL-3.0-or-later",
  "author": "",
  "sideEffects": false,
  "exports": {
    "./*": {
      "import": "./lib/*/index.js",
      "require": "./lib/*/index.js"
    }
  },
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./lib/*/index.d.ts"
      ]
    }
  },
  "scripts": {
    "lint": "eslint . --fix",
    "preinstall": "npx only-allow pnpm",
    "dev": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack serve --config ./config/webpack.config.dev.ts",
    "build": "pnpm run build-lib && pnpm run build-umd",
    "build-lib": "tsc --project tsconfig.lib.json && tsc-alias -p tsconfig.lib.json",
    "build-umd": "cross-env TS_NODE_PROJECT=\"tsconfig.json\" webpack --config ./config/webpack.config.prod.ts",
    "start": "pnpm dev"
  },
  "dependencies": {
    "@effect/typeclass": "^0.40.0",
    "effect": "^3.21.4",
    "hyperapp": "^2.0.22",
    "preact": "^10.29.4",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.8.0",
    "validate-color": "^2.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "26.1.0",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@userscript/eslint-config": "workspace:^1.0.4",
    "@userscript/webpack-config": "workspace:^1.0.6",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-airbnb-extended": "^3.1.0",
    "eslint-import-resolver-webpack": "^0.13.11",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-consistent-default-export-name": "^0.0.15",
    "eslint-plugin-import-newlines": "^1.4.1",
    "eslint-plugin-import-x": "^4.17.1",
    "globals": "^17.7.0",    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.4",
    "webpack-bundle-analyzer": "^4.10.2",
    "webpack-cli": "^7.2.1",
    "webpack-dev-server": "^6.0.0",
    "webpack-merge": "^6.0.1"
  }
}
